# =============================================================================
# aura-harness environment configuration
# =============================================================================

# LLM Routing: "proxy" (default) or "direct"
# - proxy: routes through aura-router with JWT auth (no API key needed locally)
# - direct: calls the LLM provider API directly with an API key
AURA_LLM_ROUTING=proxy

# -- Proxy mode (default) -----------------------------------------------------
# URL of the aura-router service
AURA_ROUTER_URL=https://aura-router.onrender.com

# JWT token for terminal/CLI sessions (WebSocket clients provide their own)
# AURA_ROUTER_JWT=

# -- Direct mode ---------------------------------------------------------------
# Required when AURA_LLM_ROUTING=direct
# AURA_ANTHROPIC_API_KEY=sk-ant-...
# AURA_ANTHROPIC_BASE_URL=https://api.anthropic.com

# -- E2E integration tests -----------------------------------------------------
# Credentials for zOS login (used to obtain a JWT for proxy API tests)
# E2E_ZOS_EMAIL=
# E2E_ZOS_PASSWORD=
# Optional: override bind address for the test server (default: 127.0.0.1:0)
# E2E_BIND_ADDR=127.0.0.1:0

# -- Shared --------------------------------------------------------------------
# AURA_ANTHROPIC_MODEL=claude-opus-4-6
# AURA_MODEL_TIMEOUT_MS=60000
# AURA_DATA_DIR=./aura_data
# Override the default per-user node data dir when you want a repo-local store.

# -- Node HTTP/WS authentication ---------------------------------------------
# The aura-node router ships with its `Authorization: Bearer` gate OFF by
# default. Set AURA_NODE_REQUIRE_AUTH=1 (or true) to re-enable the full
# shared-secret flow: a 32-byte hex token is minted / read from
# $AURA_DATA_DIR/auth_token, every non-/health route requires it, and the
# embedded TUI API server prints the token to stderr on startup. Pair it
# with AURA_NODE_AUTH_TOKEN to pin the value (e.g. for CI).
# AURA_NODE_REQUIRE_AUTH=0
# AURA_NODE_AUTH_TOKEN=
